generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  scheduleDates   ScheduleDate[]
  scheduleWeekdays ScheduleWeekday[]
  accessLogs      AccessLog[]

  @@map("customers")
}

model ScheduleDate {
  id         String   @id @default(uuid())
  customerId String
  date       DateTime @db.Date
  startTime  String   // HH:mm format
  endTime    String   // HH:mm format
  enabled    Boolean  @default(true)

  customer   Customer   @relation(fields: [customerId], references: [id])
  accessLogs AccessLog[]

  @@map("schedule_dates")
}

model ScheduleWeekday {
  id         String  @id @default(uuid())
  customerId String
  weekDay    Int     // 0=Sunday .. 6=Saturday
  startTime  String  // HH:mm format
  endTime    String  // HH:mm format
  enabled    Boolean @default(true)

  customer   Customer   @relation(fields: [customerId], references: [id])
  accessLogs AccessLog[]

  @@map("schedule_weekdays")
}

model AccessLog {
  id               String   @id @default(uuid())
  customerId       String?
  codeEntered      String
  success          Boolean
  action           String   // 'door_open' | 'concierge_redirect' | 'invalid_code' | 'no_schedule'
  scheduleDateId   String?
  scheduleWeekdayId String?
  createdAt        DateTime @default(now())

  customer         Customer?       @relation(fields: [customerId], references: [id])
  scheduleDate     ScheduleDate?   @relation(fields: [scheduleDateId], references: [id])
  scheduleWeekday  ScheduleWeekday? @relation(fields: [scheduleWeekdayId], references: [id])

  @@map("access_logs")
}
